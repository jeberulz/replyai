# --- Convex (required) -----------------------------------------------------
# Run `npx convex dev` once; it creates a dev deployment and prints the URL.
# CONVEX_DEPLOYMENT is written to .env.local automatically by the CLI.
NEXT_PUBLIC_CONVEX_URL=

# --- App -------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Required before Gate 10 production readiness. Use the owner-approved
# ReplyPilot support address/operator identity; do not leave old project
# placeholder contacts in legal or Settings.
REPLYPILOT_SUPPORT_EMAIL=
REPLYPILOT_OPERATOR_NAME=

# --- Private beta access ----------------------------------------------------
# Production defaults to allowlist mode. Denied X identities are rejected after
# reading the X profile and before storing a user, session, or OAuth token.
BETA_ACCESS_MODE=allowlist
BETA_ALLOWED_X_HANDLES=
BETA_ACCESS_DAYS=45
# Server-only shared secret for account/session provisioning. Use the same
# random value in Vercel and Convex; do not expose it to the browser.
CONVEX_AUTH_PROVISION_SECRET=
ENABLE_PUBLIC_DEMO=false
# The AI-spend and X-read caps below fail closed when required-but-unset. A
# user with users.unlimitedAccess=true bypasses those caps (still real API,
# not demo data) but NOT the kill switches — so a designated end-to-end test
# account works without configuring the beta budget env vars.
AI_SPEND_KILL_SWITCH=false
AI_SPEND_LIMITS_REQUIRED=true
AI_ANALYSIS_HOURLY_LIMIT=
AI_GENERATION_HOURLY_LIMIT=
X_READ_KILL_SWITCH=false
X_READ_LIMITS_REQUIRED=true
X_READ_USER_DAILY_LIMIT=
X_READ_GLOBAL_DAILY_LIMIT=
# Scanner cost dials (Convex env; unset = defaults). Raise the cadence floor to
# scan each user less often; lower the batch limit to classify fewer tweets per
# scan. Both throttle scanner AI/X spend during the beta without a redeploy.
#   npx convex env set SCANNER_MIN_CADENCE_MINUTES 45
#   npx convex env set SCANNER_SEMANTIC_BATCH_LIMIT 15
SCANNER_MIN_CADENCE_MINUTES=
SCANNER_SEMANTIC_BATCH_LIMIT=

# --- Anthropic (optional — demo generation is used when missing) ------------
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
# Base/analysis model. Analysis defaults to this (claude-opus-4-8 when unset).
ANTHROPIC_MODEL=
# Optional per-operation overrides.
# Analysis defaults to ANTHROPIC_MODEL (Opus) for angle-finding quality.
# Generation/rewrite is the high-volume cost line and now defaults to Sonnet
# even when ANTHROPIC_MODEL is unset; set ANTHROPIC_GENERATE_MODEL to override.
#   ANTHROPIC_ANALYZE_MODEL=claude-opus-4-8
#   ANTHROPIC_GENERATE_MODEL=claude-sonnet-5
ANTHROPIC_ANALYZE_MODEL=
ANTHROPIC_GENERATE_MODEL=

# --- X / Twitter OAuth 2.0 app (optional — demo mode is used when missing) --
# Create an app at https://developer.x.com with OAuth 2.0 enabled.
# Callback URL: {NEXT_PUBLIC_APP_URL}/api/auth/callback
# Scopes needed: tweet.read users.read tweet.write offline.access
# NOTE: reading tweets/timelines requires a paid X API tier (Basic or above).
# NOTE: since Feb 2026 X blocks API replies/quotes on all standard tiers
# unless the post's author mentioned or quoted you first — the app falls back
# to standalone posts and surfaces the restriction.
X_CLIENT_ID=
X_CLIENT_SECRET=
# IMPORTANT: scheduled publishing refreshes X tokens inside Convex, which has
# its own environment. Mirror both values there or refresh fails at runtime:
#   npx convex env set X_CLIENT_ID <value>
#   npx convex env set X_CLIENT_SECRET <value>

# --- Stripe billing (optional in dev; WP2 uses test mode when configured) ---
STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
# IMPORTANT: the Stripe webhook and billing actions run inside Convex too.
# Mirror all three values there or checkout/webhook sync will stay inactive:
#   npx convex env set STRIPE_SECRET_KEY <value>
#   npx convex env set STRIPE_PRO_PRICE_ID <value>
#   npx convex env set STRIPE_WEBHOOK_SECRET <value>

# --- X token security ------------------------------------------------------
# X OAuth access/refresh tokens are encrypted at rest inside Convex.
# Generate a long random value, keep it server-only, and set it in Convex:
#   openssl rand -base64 32
#   npx convex env set X_TOKEN_ENCRYPTION_KEY <value>
# This template entry documents the required secret; Next.js does not read it.
X_TOKEN_ENCRYPTION_KEY=

# Server-only shared secret that lets Next.js server actions ask Convex for
# decrypted X tokens. Use the SAME random value in .env.local and Convex:
#   openssl rand -base64 32
#   npx convex env set CONVEX_SERVER_TOKEN_ACCESS_SECRET <value>
CONVEX_SERVER_TOKEN_ACCESS_SECRET=

# Server-only shared secret for OAuth/demo session provisioning (WP40). Same value
# in Vercel and Convex when private beta is enabled; omit in local dev unless
# testing the gate:
#   openssl rand -base64 32
#   npx convex env set CONVEX_AUTH_PROVISION_SECRET <value>
CONVEX_AUTH_PROVISION_SECRET=

# --- AI spend caps (Convex only — set via `npx convex env set`) -------------
# Local dev: set AI_SPEND_LIMITS_REQUIRED=false so flows work without caps.
# Production beta: set hourly limits and keep AI_SPEND_LIMITS_REQUIRED=true.
#   npx convex env set AI_SPEND_KILL_SWITCH false
#   npx convex env set AI_SPEND_LIMITS_REQUIRED false
#   npx convex env set AI_ANALYSIS_HOURLY_LIMIT 30
#   npx convex env set AI_GENERATION_HOURLY_LIMIT 60

# --- Observability (optional — see docs/observability.md) -------------------
# Product analytics (PostHog). NEXT_PUBLIC_* reaches the browser bundle;
# POSTHOG_KEY is read server-side only. Usually the same key value in both.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
POSTHOG_KEY=
POSTHOG_HOST=
# Error tracking (Sentry). Same DSN in both — NEXT_PUBLIC_* is what reaches
# the browser bundle.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# IMPORTANT: the scanner and publish actions run inside Convex, which has its
# own environment. Mirror both keys there or those events/errors go dark:
#   npx convex env set POSTHOG_KEY <value>
#   npx convex env set SENTRY_DSN <value>

# --- Hot-window notifications (WP8, optional) ----------------------------
# Web push (VAPID). Generate with: npx web-push generate-vapid-keys
# All THREE keys are required for push; missing any leaves alerts queued
# (digest can still drain). Expose only the public key to the browser.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# IMPORTANT: push delivery runs inside Convex actions:
#   npx convex env set VAPID_PUBLIC_KEY <value>
#   npx convex env set VAPID_PRIVATE_KEY <value>
#   npx convex env set VAPID_SUBJECT mailto:you@domain.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
# Absolute origin for digest email links (Convex does not inherit Next env).
# Push deep links are relative (/feed?…) and resolve against the page origin.
#   npx convex env set APP_URL https://your-app.example
APP_URL=
# Digest email fallback (Resend). No-op when unset — never blocks alerts.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# IMPORTANT: digest cron runs inside Convex:
#   npx convex env set RESEND_API_KEY <value>
#   npx convex env set RESEND_FROM_EMAIL <value>
